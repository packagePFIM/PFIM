Max      = max(best_errors),
Min      = min(best_errors),
Fidelity = max(0, 1 - rms / 50),
Nb_EDO   = nb_edo
)
}
print_metrics <- function(m, title = "") {
cat("\n", strrep("-", 46), "\n", sep = "")
if (nchar(title) > 0) {
cat("  ", title, "\n", sep = "")
cat(strrep("-", 46), "\n", sep = "")
}
cat(sprintf("  MAE      : %.4f cents\n", m$MAE))
cat(sprintf("  RMS      : %.4f cents\n", m$RMS))
cat(sprintf("  Max      : %.4f cents\n", m$Max))
cat(sprintf("  Min      : %.4f cents\n", m$Min))
cat(sprintf("  Fidelite : %.2f%%\n",     m$Fidelity * 100))
cat(sprintf("  Nb EDO   : %s\n",
ifelse(is.na(m$Nb_EDO), "?", as.character(m$Nb_EDO))))
cat(strrep("-", 46), "\n", sep = "")
}
# --- 3. OPTIMISATION DU SUBSET D'EDO ------------------------------------------
# Greedy exact : x_i* = argmin_{n in edos} E[i,n]   O(N_notes x N_edos)
greedy_optimal <- function(edos = EDO_RANGE) {
E           <- error_matrix(CENTS, edos)
best_j      <- apply(E, 1, which.min)
assignment  <- edos[best_j]
best_errors <- E[cbind(seq_len(N_NOTES), best_j)]
m           <- compute_metrics(best_errors,
nb_edo = length(unique(assignment)))
list(edos = edos, E = E, assignment = assignment,
best_errors = best_errors, metrics = m)
}
print_assignment <- function(res) {
cat(sprintf("\n%-12s %8s %5s %8s %8s\n",
"Note", "Cible c", "EDO", "Approx c", "Erreur c"))
cat(strrep("-", 46), "\n", sep = "")
for (i in seq_len(N_NOTES)) {
n   <- res$assignment[i]
ct  <- CENTS[i]
app <- project_edo(ct, n)
err <- res$best_errors[i]
cat(sprintf("%-12s %8.2f %5d   %8.2f %7.3f c\n",
NOTE_NAMES[i], ct, n, app, err))
}
}
# Recherche exhaustive :  min_{S} [ RMS(S) + lambda * |S| / max_size ]
# 2^9 - 1 = 511 sous-ensembles : tractable
parsimonious_search <- function(edos_pool = EDO_RANGE, lambda_penalty = 2.0) {
max_size <- length(edos_pool)
results  <- list()
idx      <- 0L
for (size in seq_len(max_size)) {
combos <- combn(edos_pool, size, simplify = FALSE)
for (subset in combos) {
idx      <- idx + 1L
E        <- error_matrix(CENTS, subset)
best_j   <- apply(E, 1, which.min)
best_err <- E[cbind(seq_len(N_NOTES), best_j)]
assign   <- subset[best_j]
m        <- compute_metrics(best_err, nb_edo = size)
score    <- m$RMS + lambda_penalty * size / max_size
results[[idx]] <- list(
edos        = subset,
assignment  = assign,
best_errors = best_err,
metrics     = m,
score       = score,
E           = E
)
}
}
scores <- sapply(results, `[[`, "score")
results[order(scores)]
}
# Frontiere de Pareto (RMS, Nb_EDO) : subsets non domines
pareto_front <- function(results) {
rms_vec <- sapply(results, function(r) r$metrics$RMS)
nb_vec  <- sapply(results, function(r) r$metrics$Nb_EDO)
keep    <- logical(length(results))
for (i in seq_along(results)) {
dominated <- any(
rms_vec <= rms_vec[i] & nb_vec <= nb_vec[i] &
(rms_vec < rms_vec[i] | nb_vec < nb_vec[i])
)
keep[i] <- !dominated
}
pareto <- results[keep]
pareto[order(sapply(pareto, function(r) r$metrics$Nb_EDO))]
}
print_pareto <- function(pareto) {
cat("\n", strrep("-", 60), "\n", sep = "")
cat("  Frontiere de Pareto (RMS vs Nb EDO)\n")
cat(strrep("-", 60), "\n", sep = "")
cat(sprintf("  %7s  %-28s %7s %7s %7s\n",
"Nb EDO", "EDOs", "RMS", "MAE", "Max"))
cat(strrep("-", 60), "\n", sep = "")
for (r in pareto) {
edos_str <- paste0("{", paste(r$edos, collapse = ","), "}")
cat(sprintf("  %7d  %-28s %7.3f %7.3f %7.3f\n",
r$metrics$Nb_EDO, edos_str,
r$metrics$RMS, r$metrics$MAE, r$metrics$Max))
}
cat(strrep("-", 60), "\n", sep = "")
}
# --- 4. PLACEMENT PHYSIQUE DES FRETTES ----------------------------------------
# d_k = L * (1 - 2^{-c/1200})
fret_position <- function(cents, scale_length_mm) {
scale_length_mm * (1 - 2^(-cents / 1200))
}
# Numero de frette k dans l'EDO n
fret_number <- function(cents, n) round(cents / (1200 / n))
build_fretboard <- function(res,
scale_length_mm = 648.0,
min_spacing_mm  = 3.0) {
df <- data.frame(
note_idx     = seq_len(N_NOTES),
ratio        = NOTE_NAMES,
cents_target = CENTS,
edo          = res$assignment,
stringsAsFactors = FALSE
)
df$fret_k       <- mapply(fret_number, df$cents_target, df$edo)
df$cents_approx <- df$fret_k * 1200 / df$edo
df$pos_mm       <- fret_position(df$cents_approx, scale_length_mm)
df$error_cents  <- abs(df$cents_target - df$cents_approx)
df <- df[order(df$pos_mm), ]
rownames(df) <- NULL
df$dist_prev <- c(df$pos_mm[1], diff(df$pos_mm))
df$conflict  <- FALSE
for (i in seq_len(nrow(df))) {
if (i > 1 && df$dist_prev[i] < min_spacing_mm) {
df$conflict[i]     <- TRUE
df$conflict[i - 1] <- TRUE
}
}
df
}
resolve_conflicts <- function(fretboard, res,
scale_length_mm = 648.0,
min_spacing_mm  = 3.0) {
E    <- res$E
edos <- res$edos
df   <- fretboard
for (i in which(df$conflict)) {
note_i <- df$note_idx[i]
ranked <- edos[order(E[note_i, ])]   # tries par erreur croissante
for (n_alt in ranked[-1]) {           # saute le meilleur deja utilise
k_alt   <- fret_number(CENTS[note_i], n_alt)
c_alt   <- k_alt * 1200 / n_alt
pos_alt <- fret_position(c_alt, scale_length_mm)
if (all(abs(pos_alt - df$pos_mm[-i]) >= min_spacing_mm)) {
df$edo[i]          <- n_alt
df$fret_k[i]       <- k_alt
df$cents_approx[i] <- c_alt
df$pos_mm[i]       <- pos_alt
df$error_cents[i]  <- abs(CENTS[note_i] - c_alt)
df$conflict[i]     <- FALSE
break
}
}
}
df <- df[order(df$pos_mm), ]
rownames(df) <- NULL
df$dist_prev <- c(df$pos_mm[1], diff(df$pos_mm))
df$conflict  <- FALSE
for (i in seq_len(nrow(df))) {
if (i > 1 && df$dist_prev[i] < min_spacing_mm) {
df$conflict[i]     <- TRUE
df$conflict[i - 1] <- TRUE
}
}
df
}
print_fretboard <- function(df, scale_length_mm, title = "") {
w <- 74
cat("\n", strrep("-", w), "\n", sep = "")
lbl <- if (nchar(title) > 0) title else "Placement des frettes"
cat(sprintf("  %s  --  L = %.1f mm\n", lbl, scale_length_mm))
cat(strrep("-", w), "\n", sep = "")
cat(sprintf("  %-3s %-12s %8s %9s %5s %8s %8s %7s\n",
"#", "Ratio", "Pos(mm)", "Dist(mm)", "EDO",
"Cible c", "Approx c", "Err c"))
cat(strrep("-", w), "\n", sep = "")
for (i in seq_len(nrow(df))) {
r    <- df[i, ]
flag <- if (r$conflict) " !" else ""
cat(sprintf("  %-3d %-12s %8.2f %9.2f %5d   %8.2f %8.2f %7.3f%s\n",
i, r$ratio, r$pos_mm, r$dist_prev,
r$edo, r$cents_target, r$cents_approx, r$error_cents, flag))
}
cat(strrep("-", w), "\n", sep = "")
n_conf <- sum(df$conflict)
if (n_conf > 0)
cat(sprintf("  !  %d frette(s) en conflit\n", n_conf))
else
cat("  OK  Aucun conflit physique\n")
}
# --- 5. VISUALISATIONS --------------------------------------------------------
plot_error_matrix <- function(res,
title = "Matrice d'erreurs |eps(Ci, n)|") {
E <- res$E
rownames(E) <- NOTE_NAMES
colnames(E) <- paste0("EDO", res$edos)
df_long <- as.data.frame(E) |>
tibble::rownames_to_column("note") |>
pivot_longer(-note, names_to = "edo", values_to = "error") |>
mutate(
note = factor(note, levels = rev(NOTE_NAMES)),
edo  = factor(edo, levels = paste0("EDO", res$edos))
) |>
group_by(note) |>
mutate(best = error == min(error)) |>
ungroup()
ggplot(df_long, aes(x = edo, y = note, fill = error)) +
geom_tile(color = "white", linewidth = 0.4) +
geom_text(aes(label = sprintf("%.1f", error), color = best),
size = 2.8) +
scale_fill_gradient2(low = "#1D9E75", mid = "#FAC775", high = "#A32D2D",
midpoint = 10, name = "Erreur (cents)") +
scale_color_manual(values = c("FALSE" = "grey30", "TRUE" = "white"),
guide = "none") +
labs(title = title,
subtitle = "Minimum par ligne = meilleur EDO (texte blanc)",
x = NULL, y = NULL) +
theme_minimal(base_size = 11) +
theme(panel.grid  = element_blank(),
axis.text.x = element_text(face = "bold"),
plot.title  = element_text(size = 13, face = "bold"),
plot.subtitle = element_text(size = 9, color = "grey50"))
}
plot_pareto <- function(pareto) {
df <- data.frame(
nb_edo = sapply(pareto, function(r) r$metrics$Nb_EDO),
rms    = sapply(pareto, function(r) r$metrics$RMS),
max_e  = sapply(pareto, function(r) r$metrics$Max),
edos   = sapply(pareto, function(r) paste(r$edos, collapse = ",")),
stringsAsFactors = FALSE
)
ggplot(df, aes(x = nb_edo, y = rms)) +
geom_line(color = "#5F5E5A", linewidth = 0.8, linetype = "dashed") +
geom_point(aes(size = max_e, color = rms),
shape = 21, fill = "white", stroke = 0.8) +
geom_text(aes(label = paste0("{", edos, "}")),
nudge_y = 0.8, size = 2.8, color = "grey30") +
scale_color_gradient(low = "#1D9E75", high = "#A32D2D",
name = "RMS (cents)") +
scale_size_continuous(name = "Max err (cents)", range = c(3, 9)) +
scale_x_continuous(breaks = df$nb_edo) +
labs(title    = "Frontiere de Pareto : precision vs parcimonie",
subtitle = "Chaque point = meilleur subset pour ce nombre d'EDO",
x = "Nombre d'EDO utilises", y = "RMS (cents)") +
theme_minimal(base_size = 11) +
theme(plot.title    = element_text(size = 13, face = "bold"),
plot.subtitle = element_text(size = 9, color = "grey50"))
}
plot_fretboard <- function(df, scale_length_mm,
title = "Placement des frettes") {
neck_w   <- 45
half     <- neck_w / 2
edo_vals <- sort(unique(df$edo))
pal      <- setNames(hue_pal()(length(edo_vals)), as.character(edo_vals))
df$edo_f <- factor(df$edo)
conf_df  <- df[df$conflict, ]
ggplot() +
annotate("rect",
xmin = 0, xmax = max(df$pos_mm) * 1.05,
ymin = -half, ymax = half,
fill = "#F5E6C8", color = "#8B6914", linewidth = 1) +
annotate("segment", x = 0, xend = 0, y = -half, yend = half,
color = "#333333", linewidth = 2) +
geom_segment(data = df,
aes(x = pos_mm, xend = pos_mm,
y = -half, yend = half, color = edo_f),
linewidth = 1.2) +
geom_text(data = df,
aes(x = pos_mm, y = half + 3,
label = ratio, color = edo_f),
angle = 45, hjust = 0, size = 2.6) +
geom_text(data = df,
aes(x = pos_mm, y = -half - 2,
label = sprintf("%.1f c", error_cents)),
angle = 45, hjust = 1, size = 2.2, color = "grey40") +
{ if (nrow(conf_df) > 0)
geom_point(data = conf_df, aes(x = pos_mm, y = 0),
shape = 8, color = "#A32D2D", size = 3) } +
scale_color_manual(values = pal, name = "EDO") +
scale_x_continuous(
name   = "Distance depuis le sillet (mm)",
breaks = seq(0, max(df$pos_mm) * 1.05, by = 50),
expand = expansion(mult = c(0.01, 0.15))
) +
labs(title    = title,
subtitle = sprintf("L = %.0f mm | %d frettes | EDOs : %s",
scale_length_mm, nrow(df),
paste(edo_vals, collapse = ", ")),
y = NULL) +
theme_minimal(base_size = 11) +
theme(axis.text.y     = element_blank(),
panel.grid      = element_blank(),
axis.line.x     = element_line(color = "grey70"),
plot.title      = element_text(size = 13, face = "bold"),
plot.subtitle   = element_text(size = 9, color = "grey50"),
legend.position = "bottom")
}
# --- 6. MAIN ------------------------------------------------------------------
cat("\n", strrep("=", 56), "\n", sep = "")
cat("  OPTIMISATION EDO -- TEMPERAMENT PERSAN 17 TONS\n")
cat(strrep("=", 56), "\n", sep = "")
# 6.1  Greedy complet
full <- greedy_optimal(EDO_RANGE)
print_metrics(full$metrics, "Greedy -- tous EDO 8..16")
print_assignment(full)
# 6.2  Recherche exhaustive
cat("\n  Recherche exhaustive (lambda=2.0, 511 sous-ensembles)...\n")
all_results <- parsimonious_search(EDO_RANGE, lambda_penalty = 2.0)
pareto      <- pareto_front(all_results)
print_pareto(pareto)
# 6.3  Meilleur subset 3-EDO
best3 <- Filter(function(r) r$metrics$Nb_EDO == 3, pareto)[[1]]
print_metrics(best3$metrics,
paste("Meilleur subset 3-EDO :",
paste(best3$edos, collapse = ",")))
print_assignment(best3)
# 6.4  Placement physique
SCALE_LENGTH <- 648.0
MIN_SPACING  <- 3.0
fb_full <- build_fretboard(full, SCALE_LENGTH, MIN_SPACING)
print_fretboard(fb_full, SCALE_LENGTH, "Greedy -- tous EDO 8..16")
if (any(fb_full$conflict)) {
cat("\n  Resolution des conflits...\n")
fb_full <- resolve_conflicts(fb_full, full, SCALE_LENGTH, MIN_SPACING)
print_fretboard(fb_full, SCALE_LENGTH, "Apres resolution")
}
fb_3 <- build_fretboard(best3, SCALE_LENGTH, MIN_SPACING)
print_fretboard(fb_3, SCALE_LENGTH,
paste0("3-EDO {", paste(best3$edos, collapse = ","), "}"))
# 6.5  Exports
p1 <- plot_error_matrix(full)
p2 <- plot_pareto(pareto)
p3 <- plot_fretboard(fb_full, SCALE_LENGTH, "Manche -- Greedy tous EDO")
p4 <- plot_fretboard(fb_3,   SCALE_LENGTH,
paste0("Manche 3-EDO {",
paste(best3$edos, collapse = ","), "}"))
p1
p2
p3
p4
p3
p4
