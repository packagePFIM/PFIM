optimize_edo <- function(n) {
ratios <- c(3/2, 5/4, 6/5)  # intervalles purs
steps <- round(log(ratios) / log(2^(1/n)))
edo_ratios <- 2^(steps/n)
mean((edo_ratios - ratios)^2)
}
# Tester plusieurs EDO
results <- sapply(5:53, optimize_edo)
best_n <- which.min(results) + 4
cat("Meilleur EDO:", best_n)
optimize_edo <- function(n) {
ratios <- c(56/243,27/25, 9/8 ,32/27, 243/200,81/64 ,4/3, 25/18, 36/25, 3/2, 128/81 ,
81/50, 27/16,
16/9 ,729/400, 243/128 ,2/1)  # intervalles purs
steps <- round(log(ratios) / log(2^(1/n)))
edo_ratios <- 2^(steps/n)
mean((edo_ratios - ratios)^2)
}
# Tester plusieurs EDO
results <- sapply(5:53, optimize_edo)
best_n <- which.min(results) + 4
cat("Meilleur EDO:", best_n)
